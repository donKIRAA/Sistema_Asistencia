# Cadena de conexión de Supabase (Project Settings > Database > Connection string > URI)
# Usa el modo "Transaction" o "Session pooler" de Supabase para mejor compatibilidad con Fly.io
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres

# Credenciales de Gmail para envío de correos (usar contraseña de aplicación, no la normal)
SMTP_USER=tu_correo_real@gmail.com
SMTP_PASSWORD=tu_password_de_aplicacion_16_caracteres

# Credenciales del panel admin
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_clave

# Supabase Storage: para guardar los PDFs de memos/despidos de forma persistente
# (Render free no tiene disco persistente, así que sin esto los PDFs se perderían)
# SUPABASE_URL: Project Settings > General > Project URL (ej: https://tuvxygqzvrdttlzgrrte.supabase.co)
# SUPABASE_SERVICE_KEY: Project Settings > API Keys > service_role (secreto, NUNCA la anon/public key)
SUPABASE_URL=https://tuvxygqzvrdttlzgrrte.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key
SUPABASE_BUCKET=documentos-legales
